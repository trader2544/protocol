{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "User profile with balance, crab rating and active status",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "username": { "type": "string" },
        "balance": { "type": "number" },
        "crabRating": { "type": "number" },
        "crabsDetailsOpen": { "type": "boolean" },
        "addFundsOpen": { "type": "boolean" },
        "lotteryOpen": { "type": "boolean" },
        "giftOpen": { "type": "boolean" },
        "accountStatus": { "type": "string", "enum": ["active", "inactive"] },
        "creationDate": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "customer"] }
      },
      "required": ["email", "username", "balance", "crabRating", "accountStatus", "role"]
    },
    "CardItem": {
      "title": "CardItem",
      "description": "Card records uploaded to the marketplace",
      "type": "object",
      "properties": {
        "bin": { "type": "string" },
        "zip": { "type": "string" },
        "bank": { "type": "string" },
        "country": { "type": "string" },
        "state": { "type": "string" },
        "type": { "type": "string" },
        "creditDebit": { "type": "string" },
        "subtype": { "type": "string" },
        "expDate": { "type": "string" },
        "discounted": { "type": "boolean" },
        "onlyRefundable": { "type": "boolean" },
        "price": { "type": "number" },
        "ssn": { "type": "boolean" },
        "dob": { "type": "boolean" },
        "mmn": { "type": "boolean" },
        "ipAddress": { "type": "string" },
        "lastPaidAmount": { "type": "boolean" },
        "driverLicense": { "type": "boolean" },
        "driverLicenseScan": { "type": "boolean" },
        "atmPin": { "type": "boolean" },
        "attPin": { "type": "boolean" },
        "fullAddress": { "type": "boolean" },
        "phone": { "type": "boolean" },
        "email": { "type": "boolean" },
        "emailPassword": { "type": "boolean" },
        "withoutCvv2": { "type": "boolean" },
        "base": { "type": "string" }
      },
      "required": ["bin", "bank", "price"]
    },
    "NewsItem": {
      "title": "NewsItem",
      "description": "News bulletins shown in the tab dashboard",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "date": { "type": "string" },
        "content": { "type": "string" },
        "important": { "type": "boolean" }
      },
      "required": ["title", "date", "content"]
    },
    "WholesalePack": {
      "title": "WholesalePack",
      "description": "Wholesale cards combo bundle",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "count": { "type": "number" },
        "price": { "type": "number" },
        "description": { "type": "string" },
        "country": { "type": "string" },
        "type": { "type": "string" }
      },
      "required": ["name", "count", "price"]
    },
    "AuctionItem": {
      "title": "AuctionItem",
      "description": "Bidding card record",
      "type": "object",
      "properties": {
        "card": { "type": "object" },
        "currentBid": { "type": "number" },
        "myBid": { "type": "number" },
        "bidsCount": { "type": "number" },
        "endTime": { "type": "string" }
      },
      "required": ["card", "currentBid", "endTime"]
    },
    "SupportTicket": {
      "title": "SupportTicket",
      "description": "A live support desk help discussion thread",
      "type": "object",
      "properties": {
        "subject": { "type": "string" },
        "status": { "type": "string", "enum": ["Open", "Closed", "Replied"] },
        "createdAt": { "type": "string" },
        "userEmail": { "type": "string" },
        "messages": { "type": "array" }
      },
      "required": ["subject", "status", "createdAt", "userEmail", "messages"]
    },
    "Order": {
      "title": "Order",
      "description": "Buyer checkout order histories",
      "type": "object",
      "properties": {
        "userEmail": { "type": "string" },
        "bin": { "type": "string" },
        "bank": { "type": "string" },
        "price": { "type": "number" },
        "purchaseId": { "type": "string" },
        "timestamp": { "type": "string" },
        "details": { "type": "string" },
        "testStatus": { "type": "string" }
      },
      "required": ["userEmail", "bin", "price", "purchaseId"]
    },
    "SystemSettings": {
      "title": "SystemSettings",
      "description": "Admin adjustable parameters like crypto addresses",
      "type": "object",
      "properties": {
        "btcAddress": { "type": "string" },
        "ltcAddress": { "type": "string" },
        "ethAddress": { "type": "string" }
      },
      "required": ["btcAddress", "ltcAddress", "ethAddress"]
    }
  },
  "firestore": {
    "users/{email}": {
      "schema": "UserProfile",
      "description": "User security credentials, balances, and profiles"
    },
    "cards/{cardId}": {
      "schema": "CardItem",
      "description": "Active card catalog in the database"
    },
    "news/{newsId}": {
      "schema": "NewsItem",
      "description": "System bulletins and security news"
    },
    "wholesalePacks/{packId}": {
      "schema": "WholesalePack",
      "description": "Wholesale bundle offers"
    },
    "auctions/{auctionId}": {
      "schema": "AuctionItem",
      "description": "Bidding card auctions"
    },
    "tickets/{ticketId}": {
      "schema": "SupportTicket",
      "description": "Auditable help ticket conversations"
    },
    "orders/{orderId}": {
      "schema": "Order",
      "description": "Customer purchase receipts"
    },
    "settings/{settingId}": {
      "schema": "SystemSettings",
      "description": "Cryptocurrency deposit configurations"
    }
  }
}
