rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global safety net: deny all unrecognized paths by default
    match /{document=**} {
      allow read, write: if false;
    }

    // AUTH HELPER FUNCTIONS
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Checks if current user is admin via trusted record or seed email
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == "patrickkamande10455@gmail.com" ||
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin"
      );
    }

    // SCHEMA VALIDATORS
    function isValidProduct(data) {
      return data.title is string && data.title.size() <= 200 &&
             data.description is string && data.description.size() <= 2000 &&
             data.price is number && data.price >= 0 &&
             data.category is string && data.category.size() <= 100 &&
             data.imageUrl is string && data.imageUrl.size() <= 1000 &&
             data.stock is number && data.stock >= 0 &&
             data.postedBy is string && data.postedBy.size() <= 128;
    }

    function isValidUserProfile(data) {
      return data.userId is string && data.userId.size() <= 128 &&
             data.email is string && data.email.size() <= 128 &&
             data.username is string && data.username.size() <= 100 &&
             data.avatarUrl is string && data.avatarUrl.size() <= 1000 &&
             data.balance is number && data.balance >= 0 &&
             data.role is string && (data.role == "customer" || data.role == "admin");
    }

    // COLLECTIONS SECURITY
    
    // PRODUCTS COLLECTION
    match /products/{productId} {
      allow read: if true; // Anyone can read products in catalog
      allow create: if isValidProduct(request.resource.data);
      allow update: if isValidProduct(request.resource.data);
      allow delete: if true;
    }

    // USERS COLLECTION
    match /users/{userId} {
      allow read: if true; // Anyone can retrieve user details to check escrow balance on login
      allow create: if isValidUserProfile(request.resource.data);
      allow update: if isValidUserProfile(request.resource.data);
      allow delete: if true;
    }
  }
}
